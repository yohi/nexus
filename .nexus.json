{
  "embedding": {
    "batchSize": 32,
    "maxConcurrency": 1,
    "timeoutMs": 120000
  },
  "indexing": {
    "chunkConcurrency": 2,
    "embedBatchWindowSize": 16,
    "maxChunkChars": 3000
  },
  "watcher": {
    "debounceMs": 300,
    "ignorePaths": [
      ".worktrees",
      "node_modules",
      ".nexus",
      "dist",
      "coverage",
      ".git",
      "build",
      "out",
      ".cache",
      ".parcel-cache",
      "venv",
      ".venv",
      ".idea",
      ".vscode",
      ".DS_Store",
      "package-lock.json",
      ".env",
      ".omo"
    ]
  }
}
