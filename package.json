{
  "name": "@yohi/nexus",
  "version": "1.26.2",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yohi/nexus.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nexus": "dist/bin/nexus.js",
    "nexus-dashboard": "dist/bin/dashboard.js",
    "nexus-aggregator": "dist/bin/aggregator.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transport": {
      "import": "./dist/server/transport.js",
      "types": "./dist/server/transport.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && shx chmod +x dist/bin/nexus.js dist/bin/dashboard.js dist/bin/aggregator.js && npm run build -w packages/dashboard && shx mkdir -p dist/dashboard && shx cp packages/dashboard/dist/cli.js dist/dashboard/cli.js",
    "lint": "eslint src/**/*.ts vitest.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:bench": "vitest bench tests/benchmarks/**/*.bench.ts",
    "doctor": "node scripts/doctor.mjs",
    "license:check": "node scripts/license-check.mjs",
    "license:report": "license-checker --production --json --out reports/licenses.json",
    "license:notice": "generate-license-file --input package-lock.json --output NOTICE"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1081.0",
    "@aws-sdk/credential-providers": "^3.1081.0",
    "@lancedb/lancedb": "^0.18.2",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@smithy/node-http-handler": "^4.9.4",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.3",
    "ink": "^5.2.0",
    "p-limit": "^7.1.1",
    "picomatch": "^4.0.4",
    "prom-client": "^15.1.3",
    "proper-lockfile": "^4.1.2",
    "react": "18.3.1",
    "typescript": "^5.9.3",
    "xxhash-wasm": "^1.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "@types/picomatch": "^4.0.3",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.24.0",
    "generate-license-file": "^4.0.0",
    "globals": "^16.0.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.5.3",
    "shx": "^0.4.0",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.1.1"
  }
}
