{
  "name": "@yohi/nexus-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "nexus-dashboard": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./cli": "./dist/cli.js"
  },
  "scripts": {
