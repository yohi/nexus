    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
